{
  "productName": "GitStore",
  "version": "0.2.0",
  "identifier": "com.gitstore.app",
  "build": {
    "frontendDist": "http://127.0.0.1:3456",
    "devUrl": "http://127.0.0.1:3456",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "GitStore",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "backend/": "./"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
