{
  "name": "gitstore",
  "version": "0.1.0",
  "description": "App store for GitHub — install and run repos as applications",
  "type": "module",
  "bin": {
    "gitstore-mcp": "./dist/mcp/index.js"
  },
  "scripts": {
    "build": "tsc && cd web && npx vite build",
    "build:backend": "tsc",
    "build:web": "cd web && npx vite build",
    "dev": "tsc --watch",
    "dev:web": "cd web && npx vite",
    "start:mcp": "node dist/mcp/index.js",
    "start:server": "node dist/server/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.1",
    "express": "^5.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
