{
  "name": "@svetfm/gitstore",
  "version": "0.3.0",
  "description": "App store for GitHub — install and run repos as applications",
  "type": "module",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "SvetimFM",
  "homepage": "https://svetimfm.github.io/GitStore/",
  "repository": {
    "type": "git",
    "url": "https://github.com/SvetimFM/GitStore.git"
  },
  "keywords": [
    "github",
    "installer",
    "package-manager",
    "app-store",
    "cli",
    "developer-tools",
    "mcp",
    "self-hosted",
    "binary-installer"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "gitstore": "./dist/cli.js",
    "gitstore-mcp": "./dist/mcp/index.js"
  },
  "files": [
    "dist/",
    "web/dist/"
  ],
  "scripts": {
    "build": "tsc && cp -r src/data/. dist/data/ && cd web && npx vite build",
    "build:backend": "tsc",
    "build:web": "cd web && npx vite build",
    "dev": "tsc --watch",
    "dev:web": "cd web && npx vite",
    "start": "node dist/cli.js",
    "start:mcp": "node dist/mcp/index.js",
    "start:server": "node dist/server/start.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.1",
    "express": "^5.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
